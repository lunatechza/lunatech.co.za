{
  "name": "lunatech-2026",
  "version": "1.0.0",
  "description": "Lunatech 2026 Modernized Website",
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/input.css -o ./css/style.css",
    "build:html": "posthtml -c .posthtmlrc.js",
    "build": "npm run build:css && npm run build:html",
    "watch": "npm run build:css -- --watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.19",
    "posthtml-cli": "^0.10.0",
    "posthtml-include": "^1.7.4",
    "tailwindcss": "^3.4.3"
  }
}
